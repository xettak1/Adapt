# Adapt frontend configuration.
# Copy to `.env` (or `.env.local`) to connect the live backend.

# Use the real Spring Boot backend instead of in-app mock data.
# Leave unset (or any value other than "false") to keep mock mode.
VITE_USE_MOCK=false

# Base URL of the Adapt backend API (note the /api/v1 suffix).
VITE_API_URL=http://localhost:8080/api/v1
