# Adapt local configuration.
# Copy to `.env` for Docker Compose or `.env.local` for Vite-only frontend runs.

# Frontend port when served through Docker.
APP_PORT=3000

# Keep mock mode enabled until a backend is running.
# Set to false to use the real Spring Boot backend.
VITE_USE_MOCK=true

# Base URL of the Adapt backend API (note the /api/v1 suffix).
VITE_API_URL=http://localhost:8080/api/v1

# Postgres settings for Docker Compose.
POSTGRES_DB=adapt
POSTGRES_USER=adapt
POSTGRES_PASSWORD=adapt_dev_password
POSTGRES_PORT=5432

# Backend services should use this connection string from inside Compose.
DATABASE_URL=postgresql://adapt:adapt_dev_password@db:5432/adapt

# Spring Boot backend datasource equivalents, if/when the backend is added.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/adapt
SPRING_DATASOURCE_USERNAME=adapt
SPRING_DATASOURCE_PASSWORD=adapt_dev_password
